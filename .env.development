# Shared dev defaults — loaded automatically by `next dev`.
# SAFE TO COMMIT: contains no secrets, only offline-demo flags.
#
# This puts every collaborator straight into offline demo mode (mock auth +
# in-memory seed data) with no Supabase, Docker, or keys required.
#
# Real secrets (Supabase keys, Anthropic API key) NEVER go here — they go in
# your own .env.local, which is gitignored and overrides these values.

NEXT_PUBLIC_USE_MOCK_AUTH=true
MOCK_AUTH_DEFAULT_USERNAME=maya

# Blank = offline demo stays on. Set a real URL in .env.local to use Supabase.
NEXT_PUBLIC_SUPABASE_URL=

NEXT_PUBLIC_APP_URL=http://localhost:3100
