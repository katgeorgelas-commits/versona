# ─────────────────────────────────────────────────────────────
# Versona environment — copy to .env.local and fill in.
# NEVER commit .env.local. Service role + Anthropic keys are secrets.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — used by admin + trusted server routes ONLY.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — all AI runs server-side (claude-sonnet-4-6). Never expose to client.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Dev auth ──────────────────────────────────────────────────
# Mock auth lets us build features before real auth (the PRD's last layer).
# Set to "false" to require real Supabase Auth. Keep "true" only in dev.
NEXT_PUBLIC_USE_MOCK_AUTH=true
# Username of the seeded user the mock session logs in as.
MOCK_AUTH_DEFAULT_USERNAME=maya

# ── OAuth (auth feature — built last, leave blank until then) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
